{
  "name": "instructov-vscode",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/extension.js",
  "engines": { "vscode": "^1.96.0" },
  "activationEvents": ["onCommand:instructov.openPromptReview"],
  "contributes": {
    "commands": [{ "command": "instructov.openPromptReview", "title": "Instructov: Open Prompt Review" }]
  },
  "scripts": {
    "prepare-core": "node ./scripts/prepare-core.mjs",
    "typecheck": "npm run prepare-core && node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "build": "npm run prepare-core && node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "test": "npm run build && node --test tests/*.test.mjs",
    "package": "npm run build && node ./scripts/package.mjs"
  }
}
