{
  "name": "instructov",
  "version": "0.1.0",
  "description": "Discover, audit, and streamline AI instruction files for coding agents.",
  "main": "./dist/cli.js",
  "type": "module",
  "bin": {
    "instv": "./dist/instv.js",
    "instructov": "./dist/instv.js"
  },
  "repository": "github:arbiter-systems/instructov",
  "bugs": "https://github.com/arbiter-systems/instructov/issues",
  "homepage": "https://github.com/arbiter-systems/instructov#readme",
  "keywords": ["ai", "coding-agent", "developer-tools", "instructions", "prompt-engineering"],
  "author": "Arbiter Systems",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/instv.ts",
    "dev:watch": "tsx watch src/instv.ts",
    "doctor": "tsx src/instv.ts doctor",
    "test": "vitest run --pool threads",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "dependencies": {
    "commander": "^15.0.0",
    "fast-glob": "^3.3.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
